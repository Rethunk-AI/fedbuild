{
  "schemaVersion": 1,
  "model": "claude-opus-4-7",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(make *)",
      "Bash(brew *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(go *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(bun *)",
      "Bash(yarn *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(curl *)",
      "Bash(sudo *)",
      "Bash(podman *)",
      "Bash(kubectl *)",
      "Bash(helm *)",
      "Bash(semgrep *)",
      "Bash(actionlint *)",
      "Bash(shellcheck *)",
      "Bash(buf *)",
      "Bash(supabase *)",
      "Bash(cloudflared *)"
    ]
  },
  "env": {
    "SEMGREP_ENABLE_VERSION_CHECK": "0",
    "HOMEBREW_NO_ANALYTICS": "1",
    "NPM_CONFIG_FUND": "false",
    "NPM_CONFIG_AUDIT": "false"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "test -f /etc/fedbuild-release && . /etc/fedbuild-release && printf 'fedbuild %s @ %s\\n' \"$VERSION\" \"${GIT_COMMIT:0:10}\""
          }
        ]
      }
    ]
  }
}
